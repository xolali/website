# ── Public site ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://dreamscapesystems.com

# ── Company identity (Ghana-registered) — REQUIRED before Paystack submission ──
# Shown in the footer and on /contact. Replace with Dreamscape's real details.
NEXT_PUBLIC_COMPANY_REG=CS-XXXXXXXXXX          # Ghana RGD registration number
NEXT_PUBLIC_COMPANY_ADDRESS=Street, Accra, Ghana
NEXT_PUBLIC_COMPANY_PHONE=+233 XX XXX XXXX

# ── Payments (Paystack — Ghana / GHS enabled account) ─────────────────────────
# Server-side secret used to initialize & verify transactions. Never expose.
PAYSTACK_SECRET_KEY=sk_live_or_test_xxx
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_live_or_test_xxx

# ── Form delivery (optional; uses Resend if set, otherwise logs) ──────────────
CONTACT_INBOX=hello@dreamscapesystems.com
SUPPORT_INBOX=support@dreamscapesystems.com
# RESEND_API_KEY=
# NOTIFY_FROM=Dreamscape Systems <no-reply@dreamscapesystems.com>
